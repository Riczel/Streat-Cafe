<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    tools:context=".User_Profile">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textColor="@color/dark_brown"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingBottom="24dp">

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivProfilePic"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Profile Picture"
                            android:padding="2dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/istockphoto_1225790722_612x612_removebg_preview"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            app:strokeColor="@color/dark_brown"
                            app:strokeWidth="2dp" />

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/btnChangePic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignEnd="@id/ivProfilePic"
                            android:layout_alignBottom="@id/ivProfilePic"
                            android:layout_marginStart="2dp"
                            android:layout_marginTop="2dp"
                            android:layout_marginEnd="-3dp"
                            android:layout_marginBottom="-2dp"
                            app:backgroundTint="@color/bg_cream"
                            app:elevation="3dp"
                            app:fabCustomSize="30dp"
                            app:srcCompat="@android:drawable/ic_menu_camera"
                            app:tint="@color/black" />
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/layoutPicOptions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/btnPicChange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/edit_text_rounded"
                            android:backgroundTint="@color/accent_tan"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Change"
                            android:textColor="@color/dark_brown"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnPicRemove"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/edit_text_rounded"
                            android:backgroundTint="@color/accent_tan"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Remove"
                            android:textColor="#FF0000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="User Name"
                        android:textColor="@color/dark_brown"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@email.com"
                        android:textColor="#5D4037" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERSONAL INFORMATION"
                        android:textColor="@color/dark_brown"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/btnEditPersonal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Edit"
                        android:textColor="#5D4037"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FIRST NAME" android:textSize="10sp" android:textStyle="bold" />
                        <EditText android:id="@+id/etFirstName" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="User Name" android:enabled="false" android:inputType="textPersonName" android:textColor="@color/dark_brown" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LAST NAME" android:textSize="10sp" android:textStyle="bold" />
                        <EditText android:id="@+id/etLastName" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="User Surname" android:enabled="false" android:inputType="textPersonName" android:textColor="@color/dark_brown" />
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="PHONE NUMBER" android:textSize="10sp" android:textStyle="bold" />
                <EditText android:id="@+id/etPhoneNumber" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="4dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="09........." android:enabled="false" android:inputType="phone" android:textColor="@color/dark_brown" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DELIVERY ADDRESS"
                        android:textColor="@color/dark_brown"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnEditAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Edit"
                        android:textColor="#5D4037"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOUSE NO. &amp; STREET / PUROK / SITIO" android:textSize="9sp" android:textStyle="bold" android:minLines="2" android:gravity="bottom" />
                        <EditText android:id="@+id/etHouseNo" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. Blk0 Lot0/ Purok 1" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BARANGAY" android:textSize="9sp" android:textStyle="bold" android:minLines="2" android:gravity="bottom" />

                        <AutoCompleteTextView
                            android:id="@+id/etBarangay"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/edit_text_rounded"
                            android:backgroundTint="@color/accent_tan"
                            android:enabled="false"
                            android:hint="Select Barangay"
                            android:inputType="none"
                            android:paddingHorizontal="12dp"
                            android:textSize="13sp"
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/dark_brown" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MUNICIPALITY" android:textSize="9sp" android:textStyle="bold" />
                        <EditText android:id="@+id/etMunicipality" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. General Mamerto Natividad" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROVINCE" android:textSize="9sp" android:textStyle="bold" />
                        <EditText android:id="@+id/etProvince" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. Nueva Ecija" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAlternativeAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALTERNATIVE ADDRESS"
                            android:textColor="@color/dark_brown"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                        <LinearLayout
                            android:id="@+id/layoutAltTopButtons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:orientation="horizontal"
                            android:visibility="gone">
                            <TextView
                                android:id="@+id/btnEditAlt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Edit"
                                android:textColor="#5D4037"
                                android:textSize="12sp"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingEnd="12dp" />
                            <TextView
                                android:id="@+id/btnDeleteAlt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delete"
                                android:textColor="#FF0000"
                                android:textSize="12sp"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOUSE NO. &amp; STREET / PUROK / SITIO" android:textSize="9sp" android:textStyle="bold" android:minLines="2" android:gravity="bottom" />
                            <EditText android:id="@+id/etAltHouseNo" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. Blk0 Lot0/ Purok 1" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BARANGAY" android:textSize="9sp" android:textStyle="bold" android:minLines="2" android:gravity="bottom" />

                            <AutoCompleteTextView
                                android:id="@+id/etAltBarangay"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:background="@drawable/edit_text_rounded"
                                android:backgroundTint="@color/accent_tan" android:enabled="false" android:hint="Select Barangay" android:inputType="none" android:paddingHorizontal="12dp" android:textSize="13sp" android:focusable="false" android:clickable="true" android:textColor="@color/dark_brown" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MUNICIPALITY" android:textSize="9sp" android:textStyle="bold" />
                            <EditText android:id="@+id/etAltMunicipality" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. General Mamerto Natividad" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROVINCE" android:textSize="9sp" android:textStyle="bold" />
                            <EditText android:id="@+id/etAltProvince" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_rounded" android:backgroundTint="@color/accent_tan" android:paddingHorizontal="12dp" android:textSize="13sp" android:hint="ex. Nueva Ecija" android:enabled="false" android:inputType="text" android:textColor="@color/dark_brown" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutAltBottomButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="end"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <TextView
                            android:id="@+id/btnCancelAlt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancel"
                            android:textColor="#FF0000"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp" />
                        <TextView
                            android:id="@+id/btnSaveAlt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Save"
                            android:textColor="@color/dark_brown"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/btnAddAddress"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/edit_text_rounded"
                    android:backgroundTint="@color/accent_tan"
                    android:gravity="center"
                    android:text="+ Add Alternative Address"
                    android:textColor="@color/dark_brown"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutEditControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/accent_tan"
                        android:text="Cancel"
                        android:textColor="@color/dark_brown" />
                    <Button
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="@color/card_brown"
                        android:text="Save"
                        android:textColor="@color/text_white_cream" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btnMyCart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/screenshot_2026_02_08_124803_removebg_preview" app:tint="@color/dark_brown" android:contentDescription="@null" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="My Cart" android:textColor="@color/dark_brown" android:textStyle="bold" />
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_play" app:tint="#858585" android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnRecentOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/recent_svgrepo_com" app:tint="@color/dark_brown" android:contentDescription="@null" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Recent Orders" android:textColor="@color/dark_brown" android:textStyle="bold" />
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_play" app:tint="#858585" android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSignOut"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="#FFF5F5"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/sign_out_2_svgrepo_com" app:tint="#FF0000" android:contentDescription="@null" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Sign Out" android:textColor="#FF0000" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/accent_tan"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/_407802_200_removebg_preview" app:tint="@color/dark_brown" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="@color/dark_brown" android:textSize="10sp" tools:ignore="SmallSp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navMenu" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/waitress_icon_on_transparent_background_260nw_2342956133_removebg_preview" app:tint="@color/dark_brown" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MENU" android:textColor="@color/dark_brown" android:textSize="10sp" tools:ignore="SmallSp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navDiscover" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/search_icon_isolated_on_white_background_creative_modern_logo_vector_removebg_preview" app:tint="@color/dark_brown" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DISCOVER" android:textColor="@color/dark_brown" android:textSize="10sp" tools:ignore="SmallSp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navOrders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/order_button" app:tint="@color/dark_brown" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ORDERS" android:textColor="@color/dark_brown" android:textSize="10sp" tools:ignore="SmallSp" />
        </LinearLayout>
