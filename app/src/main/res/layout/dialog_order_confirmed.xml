<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Icon -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/order_button"
            android:contentDescription="@null"
            app:tint="#3E2723" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Order Placed!"
            android:textColor="#3E2723"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Thank you for your order! Your coffee is being prepared."
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Info Rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order ID:" android:textColor="#888888" />
                <TextView android:id="@+id/confOrderID" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="#SC-000000" android:textColor="#000000" android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Items Ordered:" android:textColor="#888888" />
                <TextView android:id="@+id/confItems" android:layout_width="200dp" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:text="Items list here..." android:textColor="#000000" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Amount:" android:textColor="#888888" />
                <TextView android:id="@+id/confTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="₱ 0.00" android:textColor="#3E2723" android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivery Address:" android:textColor="#888888" />
                <TextView android:id="@+id/confAddress" android:layout_width="200dp" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:text="Address here..." android:textColor="#000000" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payment Method:" android:textColor="#888888" />
                <TextView android:id="@+id/confPayment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Cash on Delivery" android:textColor="#000000" />
            </RelativeLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#4A321F"
            android:text="Check in Orders!"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="25dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
