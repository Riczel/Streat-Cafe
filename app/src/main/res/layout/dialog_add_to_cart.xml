<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    android:layout_gravity="center"
    android:layout_margin="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/dialogProductImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/coffee_removebg_preview"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/dialogBtnClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_margin="12dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="#80000000"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFEFE"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Close" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/dialogProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product Name"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialogProductPriceDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="₱ 0.00"
                    android:textColor="#3E2723"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/dialogProductDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Product description..."
                    android:textColor="#777777"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

                <LinearLayout
                    android:id="@+id/sectionSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIZE CHOICE"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/sizeMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_selected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="5dp"
                            android:text="Medium"
                            android:textColor="#FFFFFF"
                            android:layout_marginEnd="8dp"
                            android:textSize="12sp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/sizeLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_unselected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="5dp"
                            android:text="Large"
                            android:textColor="#000000"
                            android:textSize="12sp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/sectionSweetness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUGAR LEVEL"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/sweet0"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_option_unselected"
                            android:gravity="center"
                            android:paddingVertical="5dp"
                            android:text="0%"
                            android:textColor="#000000"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/sweet50"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_option_selected"
                            android:gravity="center"
                            android:paddingVertical="5dp"
                            android:text="50%"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/sweet75"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_option_unselected"
                            android:gravity="center"
                            android:paddingVertical="5dp"
                            android:text="75%"
                            android:textColor="#000000"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/sweet100"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_option_unselected"
                            android:gravity="center"
                            android:paddingVertical="5dp"
                            android:text="100%"
                            android:textColor="#000000"
                            android:textSize="12sp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/sectionAddons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:id="@+id/tvAddonTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADD-ONS"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:id="@+id/addonCheesecake"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:layout_marginBottom="4dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:id="@+id/iconCheesecake"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_centerVertical="true"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/textCheesecake"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/iconCheesecake"
                                android:layout_marginStart="8dp"
                                android:text="Cheesecake"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/priceCheesecake"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+₱ 0.00"
                                android:textSize="11sp"
                                android:textColor="#888888" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/addonPearl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:layout_marginBottom="4dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:id="@+id/iconPearl"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_centerVertical="true"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/textPearl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/iconPearl"
                                android:layout_marginStart="8dp"
                                android:text="Pearl"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/pricePearl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+₱ 0.00"
                                android:textSize="11sp"
                                android:textColor="#888888" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/addonNata"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:layout_marginBottom="4dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:id="@+id/iconNata"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_centerVertical="true"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/textNata"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/iconNata"
                                android:layout_marginStart="8dp"
                                android:text="Nata"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/priceNata"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+₱ 0.00"
                                android:textSize="11sp"
                                android:textColor="#888888" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/addonCoffeeJelly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:layout_marginBottom="4dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:id="@+id/iconCoffeeJelly"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_centerVertical="true"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/textCoffeeJelly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/iconCoffeeJelly"
                                android:layout_marginStart="8dp"
                                android:text="Coffee Jelly"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/priceCoffeeJelly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+₱ 0.00"
                                android:textSize="11sp"
                                android:textColor="#888888" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/addonFruitJelly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:id="@+id/iconFruitJelly"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_centerVertical="true"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/textFruitJelly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/iconFruitJelly"
                                android:layout_marginStart="8dp"
                                android:text="Fruit Jelly"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/priceFruitJelly"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+₱ 0.00"
                                android:textSize="11sp"
                                android:textColor="#888888" />
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp"
            android:paddingTop="8dp"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_unselected"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/dialogBtnMinus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="-"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/dialogTvQty"
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dialogBtnPlus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <Button
                    android:id="@+id/dialogBtnConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:backgroundTint="#4A321F"
                    android:text="Add to Cart"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="22dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
